# Server
PORT=5000
BACKEND_URL=http://localhost:5000

# Database (Railway MySQL proxy for local dev)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=meroghar_db

# Frontend
FRONTEND_URL=http://localhost:5173

# JWT Secret — change to a random string in production
JWT_SECRET=change-this-to-a-random-secret

# AI Chatbot (Google Gemini) — get free key at https://aistudio.google.com/apikey
# Leave empty to use built-in rule-based fallback
GEMINI_API_KEY=

# OpenRouteService (geocoding + distance matrix) — get free key at https://openrouteservice.org/dev/#/login
ORS_API_KEY=
